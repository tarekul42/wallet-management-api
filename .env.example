PORT=5000
DB_URL=mongodb+srv://<DBuser>:<DBPassword>@cluster0.9pu2i.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
NODE_ENV=development

# BCRYPT
BCRYPT_SALT_ROUND=10

# JWT (JSON Web Token)
# Generate strong secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_ACCESS_SECRET=YOUR_GENERATED_ACCESS_SECRET_HERE
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=YOUR_GENERATED_REFRESH_SECRET_HERE
JWT_REFRESH_EXPIRES=7d

# CORS Configuration
# Comma-separated list of allowed origins (e.g., http://localhost:5173,https://yourdomain.com)
CORS_ORIGIN=http://localhost:5173
CLIENT_URL=http://localhost:5173
COOKIE_DOMAIN=localhost

# Super Admin Credentials
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=super-secret-password

# Express Session
EXPRESS_SESSION_SECRET=YOUR_GENERATED_SESSION_SECRET_HERE

# Demo Users (for portfolio review)
DEMO_USER_EMAIL=demo.user@example.com
DEMO_USER_PASSWORD=DemoUser123!
DEMO_AGENT_EMAIL=demo.agent@example.com
DEMO_AGENT_PASSWORD=DemoAgent123!
DEMO_ADMIN_EMAIL=demo.admin@example.com
DEMO_ADMIN_PASSWORD=DemoAdmin123!

# Google OAuth (optional - for social login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Facebook OAuth (optional - for social login)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/v1/auth/facebook/callback
