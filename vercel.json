{
  "version": 2,
  "buildCommand": "bun build ./src/server.ts --outdir ./dist --target node",
  "outputDirectory": "dist",
  "devCommand": "bun run dev",
  "installCommand": "bun install",
  "framework": "express",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/server.js"
    }
  ]
}
